<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản lý tài khoản</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin-users.css">
</head>
<body>
    <%- include('./partials/navbar') %>

    <main class="container">
        <section class="page-hero compact-hero">
            <div>
                <p class="eyebrow">Admin Users</p>
                <h1>Quản lý tài khoản người dùng</h1>
                <p class="hero-copy">Cập nhật thông tin cá nhân, tên đăng nhập và phân quyền admin/user.</p>
            </div>
        </section>

        <div style="margin-bottom: 20px; margin-top: 20px;">
            <a href="/admin" class="secondary-btn" style="text-decoration: none;">&larr; Quay lại trang quản trị</a>
        </div>

        <% if (success) { %>
            <p class="status-message success-message"><%= success %></p>
        <% } %>

        <% if (error) { %>
            <p class="status-message error-message"><%= error %></p>
        <% } %>

        <section class="admin-document-card">
            <h2 class="admin-form-title">Tạo tài khoản mới</h2>
            <form action="/admin/users/create" method="POST" class="upload-form slim-form">
                <div class="form-grid">
                    <label>
                        Họ và tên
                        <input type="text" name="fullName" value="<%= formData.fullName || '' %>" required>
                    </label>

                    <label>
                        Email
                        <input type="email" name="email" value="<%= formData.email || '' %>" required>
                    </label>

                    <label>
                        Số điện thoại
                        <input type="text" name="phone" value="<%= formData.phone || '' %>">
                    </label>

                    <label>
                        Tên đăng nhập
                        <input type="text" name="username" value="<%= formData.username || '' %>" required>
                    </label>

                    <label>
                        Mật khẩu
                        <input type="password" name="password" required>
                    </label>

                    <label>
                        Vai trò
                        <select name="role" required>
                            <option value="user" <%= formData.role === 'user' ? 'selected' : '' %>>User</option>
                            <option value="admin" <%= formData.role === 'admin' ? 'selected' : '' %>>Admin</option>
                        </select>
                    </label>
                </div>

                <button type="submit" class="primary-btn">Tạo tài khoản</button>
            </form>
        </section>

        <!-- Search and Filter Form -->
        <form class="filter-form" action="/admin/users" method="GET" style="margin-bottom: 24px; margin-top: 24px;">
            <input
                type="text"
                name="q"
                value="<%= filters.q %>"
                placeholder="Tìm tên, email, sđt hoặc username..."
                class="search-box page-search"
                style="width: 320px;"
            >

            <select name="role" class="category-select">
                <option value="">Tất cả vai trò</option>
                <option value="user" <%= filters.role === 'user' ? 'selected' : '' %>>User</option>
                <option value="admin" <%= filters.role === 'admin' ? 'selected' : '' %>>Admin</option>
            </select>

            <button type="submit" class="primary-btn">Lọc tài khoản</button>
        </form>

        <section class="admin-users-section">
    <div class="admin-users-header">
        <div>
            <p class="eyebrow">Danh sách tài khoản</p>
            <h2>Tài khoản hiện có</h2>
        </div>

        <span class="helper-text">
            Tổng cộng: <strong><%= users.length %></strong> tài khoản
        </span>
    </div>

    <div class="admin-table-wrapper">
        <table class="admin-users-table">
            <thead>
                <tr>
                    <th>Họ và tên</th>
                    <th>Email</th>
                    <th>Số điện thoại</th>
                    <th>Tên đăng nhập</th>
                    <th>Vai trò</th>
                    <th>Ngày tạo</th>
                    <th>Thao tác</th>
                </tr>
            </thead>

            <tbody>
                <% users.forEach(item => { %>
                    <tr>
                        <td>
                            <input
                                form="update-user-<%= item.id %>"
                                type="text"
                                name="fullName"
                                value="<%= item.fullName %>"
                                required>
                        </td>

                        <td>
                            <input
                                form="update-user-<%= item.id %>"
                                type="email"
                                name="email"
                                value="<%= item.email || '' %>"
                                required>
                        </td>

                        <td>
                            <input
                                form="update-user-<%= item.id %>"
                                type="text"
                                name="phone"
                                value="<%= item.phone || '' %>"
                                placeholder="Chưa có">
                        </td>

                        <td>
                            <input
                                form="update-user-<%= item.id %>"
                                type="text"
                                name="username"
                                value="<%= item.username %>"
                                required>
                        </td>

                        <td>
                            <select
                                form="update-user-<%= item.id %>"
                                name="role"
                                required>
                                <option
                                    value="user"
                                    <%= item.role === 'user' ? 'selected' : '' %>>
                                    User
                                </option>

                                <option
                                    value="admin"
                                    <%= item.role === 'admin' ? 'selected' : '' %>>
                                    Admin
                                </option>
                            </select>
                        </td>

                        <td class="admin-date-cell">
                            <%= new Date(item.createdAt).toLocaleString('vi-VN') %>
                        </td>

                        <td>
                            <div class="admin-table-actions">
                                <form
                                    id="update-user-<%= item.id %>"
                                    action="/admin/users/<%= item.id %>/update"
                                    method="POST">

                                    <button type="submit" class="primary-btn">
                                        Lưu
                                    </button>
                                </form>

                                <form
                                    action="/admin/users/<%= item.id %>/delete"
                                    method="POST"
                                    onsubmit="return confirm('Bạn có chắc muốn xóa tài khoản này không?');">

                                    <button type="submit" class="danger-btn">
                                        Xóa
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</section>
    </main>

    <script src="/js/navbar.js"></script>
</body>
</html>
